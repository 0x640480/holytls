# Python build artifacts
__pycache__/
*.py[cod]
build/
dist/
*.egg-info/
.eggs/

# cffi out-of-line build outputs (regenerated by holytls_build.py on install)
holytls/_holytls_cffi.c
holytls/_holytls_cffi*.o
holytls/_holytls_cffi*.so

# native shared library staged beside the extension at build time
holytls/libholytls_capi.so*
holytls/libholytls_capi.dylib
holytls/holytls_capi.dll
