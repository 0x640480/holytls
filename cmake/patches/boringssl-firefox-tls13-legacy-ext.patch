+  // Extended master secret is not necessary in TLS 1.3 -- but Firefox sends it
+  // even in its TLS1.3-only (QUIC) ClientHello. holytls' force_tls13_legacy_ext
+  // re-enables it (an empty extension, exactly as Firefox emits).
+  if (type == ssl_client_hello_inner ||
