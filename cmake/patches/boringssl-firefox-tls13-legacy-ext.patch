+// SSL_set_force_tls13_legacy_ext configures whether |ssl| emits the legacy
+// extended_master_secret + renegotiation_info extensions even in a TLS 1.3-only
+// ClientHello (normally suppressed). Firefox sends them unconditionally.
+OPENSSL_EXPORT void SSL_set_force_tls13_legacy_ext(SSL *ssl, int enabled);
+
+// holytls:
+// SSL_CTX_set_force_tls13_legacy_ext configures whether sockets on |ctx| emit
