-  // Renegotiation indication is not necessary in TLS 1.3.
-  if (hs->min_version >= TLS1_3_VERSION ||  //
-      type == ssl_client_hello_inner) {
+  // Renegotiation indication is not necessary in TLS 1.3 -- but Firefox sends it
+  // even in its TLS1.3-only (QUIC) ClientHello. holytls' force_tls13_legacy_ext
+  // re-enables it; on a fresh handshake previous_client_finished is empty, so
+  // this emits the standard "ff01 0001 00" Firefox sends.
+  if (type == ssl_client_hello_inner ||
+      (hs->min_version >= TLS1_3_VERSION &&
+       !hs->config->force_tls13_legacy_ext)) {
     return true;
   }
 
@@ -760,8 +764,12 @@ static bool ext_ri_add_serverhello(SSL_HANDSHAKE *hs, CBB *out) {
