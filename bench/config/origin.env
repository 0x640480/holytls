# The local benchmark origin address. Sourced by start_origin.sh, the
# orchestrator, and passed to every harness via --url. Change the port here if it
# collides (8443 is commonly taken). Everything downstream reads ORIGIN_URL_BASE.
# Use the DNS name (cert has SAN DNS:localhost) so clients that verify the
# hostname as a DNS name — not an IP literal — accept the cert. localhost
# resolves to 127.0.0.1, where Caddy listens.
ORIGIN_HOST=localhost
ORIGIN_PORT=18443
ORIGIN_URL_BASE="https://${ORIGIN_HOST}:${ORIGIN_PORT}"
